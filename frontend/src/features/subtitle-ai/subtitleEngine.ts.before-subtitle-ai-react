/* ZenTask Subtitle AI engine
 * Browser-only engine for React:
 * - FFmpeg.wasm from /ffmpeg/*
 * - Whisper via Transformers.js CDN
 * - Google Translate public endpoint for SRT translation
 */

export type EngineCallbacks = {
  onLog?: (message: string) => void;
  onStatus?: (message: string) => void;
  onProgress?: (ratio: number) => void;
  onChunk?: (text: string, ratio: number) => void;
};

