# ===== AI CHAT / IMAGE =====
# Gemini: có thể dùng GEMINI_API_KEY, GEMINI_API_KEYS hoặc API_KEY_AI_1..API_KEY_AI_20.
# Nếu key hiện tại lỗi/quota/rate-limit, backend tự chuyển qua key tiếp theo.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
GEMINI_API_KEYS=
API_KEY_AI_1=
API_KEY_AI_2=
API_KEY_AI_3=
API_KEY_AI_4=
API_KEY_AI_5=

# Hugging Face image generation.
HF_TOKEN=
HF_TOKENS=
HF_IMAGE_MODEL=black-forest-labs/FLUX.1-dev
HF_PROVIDER=auto
AI_UPLOAD_MAX_MB=8

# ===== PRONUNCIATION PRACTICE =====
# API Gateway key for pronunciation scoring. Do not use Bearer; backend sends this as x-api-key by default.
PRONUNCIATION_API_KEY=
PRONUNCIATION_API_URL=https://wrg7ayuv7i.execute-api.eu-central-1.amazonaws.com/Prod/GetAccuracyFromRecordedAudio
PRONUNCIATION_API_KEY_HEADER=x-api-key
